
@using Microsoft.AspNetCore.Identity
@using Product_Management.Data;
@using Product_Management.Models
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext _context

@{
    ApplicationUser? currentUser = null;

    if (User.Identity?.IsAuthenticated == true)
    {
        currentUser = await UserManager.GetUserAsync(User);
    }

    var profileImage =
        string.IsNullOrEmpty(currentUser?.ProfileImage)
        ? "/profile/default.png"
        : "/profiles/" + currentUser.ProfileImage;

    var fullName =
        string.IsNullOrEmpty(currentUser?.FullName)
        ? User.Identity?.Name ?? "User"
        : currentUser.FullName;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PSskill</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Product_Management.styles.css" asp-append-version="true" />

    <style>

            body {
                background: #f8f9fa;
                padding-top: 72px;
            }

            /* ================================= */
            /* NAVBAR                            */
            /* ================================= */

            .navbar {
                background: #ffffff;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1050;
                box-shadow: 0 1px 8px rgba(0,0,0,0.08);
                height: 72px;
            }

                /* Allow navbar to grow taller when menu is open on mobile */
                .navbar.expanded-mobile {
                    height: auto;
                }

            .navbar-brand .ps {
                color: #f59e0b;
            }

            .navbar-brand .sk {
                color: #1d4ed8;
            }

            .nav-link {
                font-weight: 500;
                font-size: 0.92rem;
                color: #374151 !important;
                padding: 6px 10px !important;
                border-radius: 8px;
                transition: all 0.2s;
            }

                .nav-link:hover {
                    color: #1d4ed8 !important;
                    background: #eff6ff;
                }

                .nav-link.active-link {
                    color: #1d4ed8 !important;
                    background: #eff6ff;
                }

            /* Fix hamburger icon visibility on mobile */
            .navbar-toggler-icon {
                background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%2855, 65, 81, 1%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
            }

            .navbar-toggler:focus {
                box-shadow: none;
            }

            /* ADMIN DROPDOWN */
            .admin-dropdown .dropdown-toggle {
                font-size: 0.88rem;
                font-weight: 600;
                color: #dc2626 !important;
                border: 1.5px solid #fca5a5;
                border-radius: 20px;
                padding: 5px 14px !important;
                background: #fff5f5;
                transition: all 0.2s;
            }

                .admin-dropdown .dropdown-toggle:hover {
                    background: #fee2e2;
                    border-color: #dc2626;
                }

                .admin-dropdown .dropdown-toggle::after {
                    margin-left: 6px;
                }

            .dropdown-menu {
                border: none;
                box-shadow: 0 8px 24px rgba(0,0,0,0.10);
                border-radius: 12px;
                padding: 8px;
                min-width: 200px;
            }

            .dropdown-item {
                border-radius: 8px;
                font-size: 0.88rem;
                padding: 9px 14px;
                color: #374151;
                transition: background 0.15s;
            }

                .dropdown-item:hover {
                    background: #f3f4f6;
                    color: #1d4ed8;
                }

                .dropdown-item .bi {
                    width: 20px;
                }

            /* ICON BUTTONS */
            .nav-icon-btn {
                position: relative;
                width: 38px;
                height: 38px;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 10px;
                color: #374151;
                text-decoration: none;
                transition: all 0.2s;
                font-size: 1.15rem;
            }

                .nav-icon-btn:hover {
                    background: #f3f4f6;
                    color: #1d4ed8;
                }

                .nav-icon-btn .badge-dot {
                    position: absolute;
                    top: 4px;
                    right: 4px;
                    min-width: 16px;
                    height: 16px;
                    border-radius: 8px;
                    font-size: 0.62rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    padding: 0 4px;
                    font-weight: 700;
                    border: 2px solid #fff;
                }

            /* PROFILE SECTION */
            .profile-btn {
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
                padding: 5px 10px;
                border-radius: 12px;
                transition: background 0.2s;
            }

                .profile-btn:hover {
                    background: #f3f4f6;
                }

                .profile-btn img {
                    width: 38px;
                    height: 38px;
                    border-radius: 50%;
                    object-fit: cover;
                    border: 2px solid #f59e0b;
                }

                .profile-btn .profile-text .greeting {
                    font-size: 0.70rem;
                    color: #9ca3af;
                    line-height: 1;
                }

                .profile-btn .profile-text .name {
                    font-size: 0.85rem;
                    font-weight: 700;
                    color: #111827;
                    line-height: 1.3;
                    max-width: 110px;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                }

            /* DIVIDER */
            .nav-divider {
                width: 1px;
                height: 28px;
                background: #e5e7eb;
                margin: 0 4px;
            }

            footer {
                background: #fff;
            }

            /* ================================= */
            /* MOBILE FIXES                      */
            /* ================================= */

            @@media (max-width: 991.98px) {

                .navbar {
                    height: auto;
                    min-height: 72px;
                }

                .navbar-right {
                    flex-wrap: wrap;
                    justify-content: flex-start;
                    padding: 12px 0 8px;
                    gap: 6px !important;
                    border-top: 1px solid #f0f0f0;
                    margin-top: 8px;
                    width: 100%;
                }
                /* Hide profile text, show only avatar */
                .profile-btn .profile-text {
                    display: none;
                }

                .profile-btn {
                    padding: 4px;
                }
                /* Hide vertical dividers */
                .nav-divider {
                    display: none;
                }
                /* Logout button full width on mobile */
                .mobile-logout {
                    width: 100%;
                    margin-top: 4px;
                }

                    .mobile-logout button {
                        width: 100%;
                        justify-content: center;
                    }
                /* Login/Register stack on mobile */
                .mobile-auth {
                    flex-direction: column;
                    width: 100%;
                    gap: 8px !important;
                    padding-bottom: 8px;
                }

                    .mobile-auth a {
                        width: 100%;
                        text-align: center;
                    }
            }

    </style>

</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold fs-4 text-decoration-none"
                   asp-controller="Home"
                   asp-action="Index">
                    <span class="ps">PS</span><span class="sk">skill</span>
                </a>

                <!-- MOBILE TOGGLE -->
                <button class="navbar-toggler border-0"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- NAVBAR CONTENT -->
                <div class="collapse navbar-collapse" id="mainNavbar">

                    <!-- LEFT LINKS -->
                    <ul class="navbar-nav me-auto ms-lg-3 gap-1">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Dashboard"
                               asp-action="Index">
                                Dashboard
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <!-- ADMIN DROPDOWN -->
                            <li class="nav-item dropdown admin-dropdown">
                                <a class="nav-link dropdown-toggle"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    <i class="bi bi-shield-fill me-1"></i>
                                    Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Admin"
                                           asp-action="Index">
                                            <i class="bi bi-speedometer2 me-2"></i>
                                            Dashboard
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Products"
                                           asp-action="Index">
                                            <i class="bi bi-box-seam me-2"></i>
                                            Products
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Admin"
                                           asp-action="Orders">
                                            <i class="bi bi-bag-check me-2"></i>
                                            Orders
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Admin"
                                           asp-action="Users">
                                            <i class="bi bi-people me-2"></i>
                                            Users
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Categories"
                                           asp-action="Index">
                                            <i class="bi bi-tags me-2"></i>
                                            Categories
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Admin"
                                           asp-action="Inbox">
                                            <i class="bi bi-inbox me-2"></i>
                                            Messages
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider mx-2" /></li>
                                    <li>
                                        <a class="dropdown-item text-warning fw-semibold"
                                           asp-controller="Admin"
                                           asp-action="Broadcast">
                                            <i class="bi bi-megaphone-fill me-2"></i>
                                            Broadcast
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                    </ul>

                    <!-- RIGHT SECTION -->
                    <div class="navbar-right d-flex align-items-center gap-2 mt-2 mt-lg-0">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- CART -->
                            <a asp-controller="Cart"
                               asp-action="Index"
                               class="nav-icon-btn">
                                <i class="bi bi-cart3"></i>
                                @{
                                    var cartCount =
                                        Context.Session.GetInt32("CartCount") ?? 0;
                                }
                                @if (cartCount > 0)
                                {
                                    <span class="badge-dot bg-warning text-dark">
                                        @cartCount
                                    </span>
                                }
                            </a>

                            <!-- NOTIFICATIONS -->
                            <a asp-controller="Notification"
                               asp-action="Index"
                               class="nav-icon-btn">
                                <i class="bi bi-bell"></i>
                                @{
                                    var notifCount = currentUser != null
                                        ? _context.Notifications.Count(x =>
                                            x.UserId == currentUser.Id && !x.IsRead)
                                        : 0;
                                }
                                @if (notifCount > 0)
                                {
                                    <span class="badge-dot bg-danger text-white">
                                        @notifCount
                                    </span>
                                }
                            </a>

                            <!-- MESSAGES -->
                            <a asp-controller="Message"
                               asp-action="Inbox"
                               class="nav-icon-btn">
                                <i class="bi bi-chat-dots"></i>
                            </a>

                            <div class="nav-divider"></div>

                            <!-- PROFILE -->
                            <a asp-controller="Profile"
                               asp-action="Index"
                               class="profile-btn">
                                <img src="@profileImage" alt="profile" />
                                <div class="profile-text">
                                    <div class="greeting">Welcome back</div>
                                    <div class="name">@fullName</div>
                                </div>
                            </a>

                            <div class="nav-divider"></div>

                            <!-- LOGOUT -->
                            <form asp-area="Identity"
                                  asp-page="/Account/Logout"
                                  method="post"
                                  class="mobile-logout">
                                <button type="submit"
                                        class="btn btn-sm btn-outline-danger rounded-pill px-3 d-flex align-items-center gap-1"
                                        style="font-size:0.82rem;">
                                    <i class="bi bi-box-arrow-right"></i>
                                    Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="d-flex mobile-auth gap-2">
                                <a asp-area="Identity"
                                   asp-page="/Account/Login"
                                   class="btn btn-sm btn-outline-dark rounded-pill px-4">
                                    Login
                                </a>
                                <a asp-area="Identity"
                                   asp-page="/Account/Register"
                                   class="btn btn-sm btn-warning rounded-pill px-4">
                                    Register
                                </a>
                            </div>
                        }

                    </div>

                </div>

            </div>
        </nav>
    </header>

    <div class="container py-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top py-4 mt-5">
        <div class="container text-center text-muted">
            &copy; 2026 - PSskill | All Rights Reserved
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>