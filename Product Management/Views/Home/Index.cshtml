 
@model IEnumerable<Product_Management.Models.Product>

@{
    ViewData["Title"] = "Home Page";
}

<style>
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.04);
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -200% center;
        }

        100% {
            background-position: 200% center;
        }
    }

    @@keyframes countUp {
        from {
            opacity: 0;
            transform: scale(0.5);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .hero-section {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #0f172a 100%);
        border-radius: 28px;
        padding: 80px 40px;
        margin-bottom: 60px;
        position: relative;
        overflow: hidden;
    }

        .hero-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 50%, rgba(59,130,246,0.15) 0%, transparent 50%), radial-gradient(circle at 70% 50%, rgba(245,158,11,0.10) 0%, transparent 50%);
            pointer-events: none;
        }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(245,158,11,0.15);
        border: 1px solid rgba(245,158,11,0.3);
        color: #fbbf24;
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.82rem;
        font-weight: 600;
        margin-bottom: 20px;
        animation: fadeInDown 0.6s ease both;
    }

    .hero-title {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 900;
        color: #fff;
        line-height: 1.15;
        margin-bottom: 16px;
        animation: fadeInUp 0.7s ease 0.1s both;
    }

        .hero-title .highlight {
            background: linear-gradient(90deg, #fbbf24, #f59e0b, #fbbf24);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 3s linear infinite;
        }

    .hero-subtitle {
        color: #94a3b8;
        font-size: 1.05rem;
        margin-bottom: 36px;
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
        animation: fadeInUp 0.7s ease 0.2s both;
    }

    .search-box {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 20px;
        padding: 10px 10px 10px 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        max-width: 680px;
        margin: 0 auto;
        animation: fadeInUp 0.7s ease 0.3s both;
        backdrop-filter: blur(10px);
    }

        .search-box input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            font-size: 0.95rem;
            padding: 6px 8px;
        }

            .search-box input::placeholder {
                color: #64748b;
            }

        .search-box select {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 12px;
            color: #cbd5e1;
            font-size: 0.85rem;
            padding: 8px 12px;
            outline: none;
            cursor: pointer;
        }

            .search-box select option {
                background: #1e3a5f;
                color: #fff;
            }

    .search-btn {
        background: #f59e0b;
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 12px 24px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s, transform 0.15s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .search-btn:hover {
            background: #d97706;
            transform: scale(1.03);
        }

    .hero-stats {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 48px;
        flex-wrap: wrap;
        animation: fadeInUp 0.7s ease 0.4s both;
    }

    .stat-item {
        text-align: center;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 900;
        color: #fff;
        line-height: 1;
        animation: countUp 0.8s ease 0.5s both;
    }

    .stat-label {
        font-size: 0.75rem;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 4px;
    }

    .stat-divider {
        width: 1px;
        background: rgba(255,255,255,0.1);
        align-self: stretch;
    }

    .hero-float-1 {
        position: absolute;
        top: 20px;
        right: 80px;
        width: 60px;
        height: 60px;
        background: rgba(245,158,11,0.12);
        border-radius: 16px;
        animation: float 4s ease-in-out infinite;
    }

    .hero-float-2 {
        position: absolute;
        bottom: 30px;
        right: 200px;
        width: 40px;
        height: 40px;
        background: rgba(59,130,246,0.12);
        border-radius: 50%;
        animation: float 5s ease-in-out infinite 1s;
    }

    .hero-float-3 {
        position: absolute;
        top: 40px;
        left: 60px;
        width: 30px;
        height: 30px;
        background: rgba(16,185,129,0.12);
        border-radius: 8px;
        animation: float 3.5s ease-in-out infinite 0.5s;
    }

    .section-header {
        margin-bottom: 36px;
        animation: fadeInUp 0.6s ease both;
    }

    .section-tag {
        display: inline-block;
        background: #fef3c7;
        color: #d97706;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 10px;
    }

    .section-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }

    .section-subtitle {
        color: #6b7280;
        font-size: 0.9rem;
    }

    .product-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #f3f4f6;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        animation: fadeInUp 0.6s ease both;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 48px rgba(0,0,0,0.12);
            border-color: transparent;
        }

    .card-img-wrapper {
        position: relative;
        overflow: hidden;
        height: 220px;
        background: #f9fafb;
    }

        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .product-card:hover .card-img-wrapper img {
        transform: scale(1.07);
    }

    .card-img-overlay-actions {
        position: absolute;
        inset: 0;
        background: rgba(17,24,39,0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .product-card:hover .card-img-overlay-actions {
        opacity: 1;
    }

    .overlay-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #fff;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #111827;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.2s;
        transform: translateY(10px);
        opacity: 0;
    }

    .product-card:hover .overlay-btn {
        transform: translateY(0);
        opacity: 1;
    }

        .product-card:hover .overlay-btn:nth-child(2) {
            transition-delay: 0.05s;
        }

    .overlay-btn:hover {
        background: #f59e0b;
        color: #fff;
    }

    .card-badges {
        position: absolute;
        top: 12px;
        left: 12px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .badge-new {
        background: #10b981;
        color: #fff;
        font-size: 0.68rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        letter-spacing: 0.05em;
    }

    .badge-hot {
        background: #ef4444;
        color: #fff;
        font-size: 0.68rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-stock-low {
        background: #f59e0b;
        color: #fff;
        font-size: 0.68rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .wishlist-toggle {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: rgba(255,255,255,0.9);
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
        backdrop-filter: blur(4px);
    }

        .wishlist-toggle:hover {
            background: #fff;
            color: #ef4444;
            transform: scale(1.1);
        }

    .card-body-custom {
        padding: 20px;
    }

    .card-category {
        font-size: 0.72rem;
        font-weight: 600;
        color: #1d4ed8;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 6px;
    }

    .card-title-custom {
        font-size: 1rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-rating {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 12px;
    }

    .stars {
        color: #fbbf24;
        font-size: 0.78rem;
    }

    .rating-text {
        font-size: 0.75rem;
        color: #9ca3af;
    }

    .card-price-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .price-new {
        font-size: 1.2rem;
        font-weight: 900;
        color: #111827;
    }

    .price-old {
        font-size: 0.8rem;
        color: #9ca3af;
        text-decoration: line-through;
        margin-left: 6px;
    }

    .price-discount {
        font-size: 0.72rem;
        font-weight: 700;
        background: #dcfce7;
        color: #16a34a;
        padding: 3px 8px;
        border-radius: 20px;
    }

    .stock-bar-wrap {
        margin-bottom: 14px;
    }

    .stock-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.72rem;
        color: #9ca3af;
        margin-bottom: 5px;
    }

    .stock-bar {
        height: 5px;
        background: #f3f4f6;
        border-radius: 10px;
        overflow: hidden;
    }

    .stock-fill {
        height: 100%;
        border-radius: 10px;
        background: linear-gradient(90deg, #10b981, #34d399);
        transition: width 0.8s ease;
    }

    .card-footer-custom {
        display: flex;
        gap: 8px;
    }

    .btn-details {
        flex: 1;
        padding: 10px;
        border: 1.5px solid #e5e7eb;
        border-radius: 12px;
        background: #fff;
        color: #374151;
        font-size: 0.82rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
    }

        .btn-details:hover {
            border-color: #111827;
            background: #111827;
            color: #fff;
        }

    .btn-cart {
        flex: 2;
        padding: 10px;
        border: none;
        border-radius: 12px;
        background: #111827;
        color: #fff;
        font-size: 0.82rem;
        font-weight: 700;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

        .btn-cart:hover {
            background: #1d4ed8;
            color: #fff;
            transform: translateY(-1px);
        }

    .promo-banner {
        background: linear-gradient(135deg, #1d4ed8, #1e40af);
        border-radius: 24px;
        padding: 40px;
        margin: 60px 0;
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.6s ease both;
    }

        .promo-banner::after {
            content: '';
            position: absolute;
            right: -40px;
            top: -40px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .promo-banner::before {
            content: '';
            position: absolute;
            right: 60px;
            bottom: -60px;
            width: 280px;
            height: 280px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
        }

    .feature-card {
        background: #fff;
        border-radius: 20px;
        padding: 28px;
        border: 1px solid #f3f4f6;
        text-align: center;
        transition: all 0.3s;
        animation: fadeInUp 0.6s ease both;
    }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.08);
        }

    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin: 0 auto 16px;
    }

    .feature-card:nth-child(1) {
        animation-delay: 0.1s;
    }

    .feature-card:nth-child(2) {
        animation-delay: 0.2s;
    }

    .feature-card:nth-child(3) {
        animation-delay: 0.3s;
    }

    .feature-card:nth-child(4) {
        animation-delay: 0.4s;
    }
</style>

<!-- HERO -->
<section class="hero-section text-center">

    <div class="hero-float-1"> </div>
    <div class="hero-float-2"></div>
    <div class="hero-float-3"></div>

    <div class="position-relative">

        <div class="hero-badge">
            <i class="bi bi-stars"></i>
            #1 Digital Skills Marketplace
        </div>

        <h1 class="hero-title">
            Discover Amazing Products<br />
            & <span class="highlight">Grow Your Skills</span>
        </h1>

        <p class="hero-subtitle">
            Explore top-quality products, digital courses, and tools
            carefully curated to accelerate your career and business.
        </p>

        <form method="get" asp-action="Index">
            <div class="search-box">
                <i class="bi bi-search text-secondary"></i>
                <input type="text"
                       name="search"
                       placeholder="Search products, categories..." />
                <select name="categoryId"
                        onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id"
                                selected="@(ViewBag.SelectedCategory == cat.Id)">
                            @cat.Name
                        </option>
                    }
                </select>
                <button type="submit" class="search-btn">
                    <i class="bi bi-search"></i>
                    Search
                </button>
            </div>
        </form>

        <div class="hero-stats">
            <div class="stat-item">
                <div class="stat-number">500+</div>
                <div class="stat-label">Products</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-number">2K+</div>
                <div class="stat-label">Happy Customers</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-number">50+</div>
                <div class="stat-label">Categories</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-number">4.9★</div>
                <div class="stat-label">Avg Rating</div>
            </div>
        </div>

    </div>

</section>

<!-- ALL PRODUCTS -->
<section class="mb-5">
    <div class="container">

        <div class="section-header d-flex justify-content-between align-items-end">
            <div>
                <div class="section-tag">✦ All Products</div>
                <h2 class="section-title">Our Products</h2>
                <p class="section-subtitle">Browse our full collection</p>
            </div>
        </div>

        <div class="row g-4 row-cols-1 row-cols-md-2 row-cols-lg-3">

            @foreach (var item in Model)
            {
                var stockPercent = item.Quantity > 0
                    ? Math.Min(100, (item.Quantity * 10)) : 0;
                var isLowStock = item.Quantity < 5;
                var isNew = item.Id % 3 == 0;

                // ← REAL REVIEW DATA
                var reviewCount = item.Reviews?.Count ?? 0;
                var avgRating = reviewCount > 0
                    ? item.Reviews!.Average(r => r.Rating) : 0.0;
                var fullStars = (int)Math.Round(avgRating);

                <div class="col">
                    <div class="product-card h-100">

                        <div class="card-img-wrapper">

                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="~/images/@item.ImageUrl" alt="@item.Name" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                    <i class="bi bi-image text-muted" style="font-size:3rem;"></i>
                                </div>
                            }

                            <div class="card-badges">
                                @if (isNew)
                                {
                                    <span class="badge-new">NEW</span>
                                }
                                @if (isLowStock && item.Quantity > 0)
                                {
                                    <span class="badge-stock-low">LOW STOCK</span>
                                }
                                @if (item.Quantity == 0)
                                {
                                    <span class="badge-hot">SOLD OUT</span>
                                }
                            </div>

                            <button class="wishlist-toggle">
                                <i class="bi bi-heart"></i>
                            </button>

                            <div class="card-img-overlay-actions">
                                <a asp-controller="Products"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="overlay-btn"
                                   title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-controller="Cart"
                                   asp-action="Add"
                                   asp-route-id="@item.Id"
                                   class="overlay-btn"
                                   title="Add to Cart">
                                    <i class="bi bi-cart-plus"></i>
                                </a>
                            </div>

                        </div>

                        <div class="card-body-custom">

                            <div class="card-category">
                                @(item.Category?.Name ?? "General")
                            </div>

                            <div class="card-title-custom">
                                @item.Name
                            </div>

                            <!-- REAL RATING -->
                            <div class="card-rating">
                                @if (reviewCount > 0)
                                {
                                    <span class="stars">
                                        @for (int s = 1; s <= 5; s++)
                                        {
                                            if (s <= fullStars)
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {
                                                <span style="color:#d1d5db;">★</span>
                                            }
                                        }
                                    </span>
                                    <span class="rating-text">
                                        @avgRating.ToString("0.0")
                                        (@reviewCount @(reviewCount == 1 ? "review" : "reviews"))
                                    </span>
                                }
                                else
                                {
                                    <span style="color:#d1d5db;">★★★★★</span>
                                    <span class="rating-text">No reviews yet</span>
                                }
                            </div>

                            <div class="card-price-row">
                                <div>
                                    <span class="price-new">
                                        ₦@item.Price.ToString("N0")
                                    </span>
                                    <span class="price-old">
                                        ₦@((item.Price * 1.15m).ToString("N0"))
                                    </span>
                                </div>
                                <span class="price-discount">13% OFF</span>
                            </div>

                            <div class="stock-bar-wrap">
                                <div class="stock-label">
                                    <span>Stock</span>
                                    <span>@item.Quantity units left</span>
                                </div>
                                <div class="stock-bar">
                                    <div class="stock-fill"
                                         style="width:@(Math.Min(stockPercent, 100))%;">
                                    </div>
                                </div>
                            </div>

                            <div class="card-footer-custom">
                                <a asp-controller="Products"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn-details">
                                    Details
                                </a>
                                <a asp-controller="Cart"
                                   asp-action="Add"
                                   asp-route-id="@item.Id"
                                   class="btn-cart">
                                    <i class="bi bi-cart-plus"></i>
                                    Add to Cart
                                </a>
                            </div>

                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</section>

<!-- PROMO BANNER -->
<section class="container">
    <div class="promo-banner">
        <div class="row align-items-center position-relative">
            <div class="col-md-8">
                <div style="font-size:0.75rem; color:#93c5fd;
                    font-weight:700; letter-spacing:0.1em;
                    text-transform:uppercase; margin-bottom:10px;">
                    Limited Time Offer
                </div>
                <h3 style="color:#fff; font-weight:900;
                    font-size:1.7rem; margin-bottom:10px;">
                    Get 20% Off Your First Order
                </h3>
                <p style="color:#93c5fd; margin-bottom:24px;
                    font-size:0.92rem;">
                    Sign up today and use code
                    <strong style="color:#fbbf24;">FIRST20</strong>
                    at checkout.
                </p>
                <a asp-area="Identity"
                   asp-page="/Home/Index"
                   style="background:#fbbf24; color:#000;
                    padding:12px 28px; border-radius:14px;
