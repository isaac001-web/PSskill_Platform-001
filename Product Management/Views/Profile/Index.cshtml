@model Product_Management.Models.ApplicationUser

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <!-- HEADER -->

                <div class="bg-dark text-white p-4">

                    <h2 class="fw-bold mb-1">
                        My Profile
                    </h2>

                    <p class="mb-0 text-light">
                        Update your account information
                    </p>

                </div>

                <!-- BODY -->

                <div class="card-body p-4 p-lg-5">

                    <!-- SUCCESS MESSAGE -->
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-pill">

                            @TempData["Success"]

                        </div>
                    }

                    <!-- ERROR MESSAGE -->
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger rounded-pill">

                            @TempData["Error"]

                        </div>
                    }

                    <form asp-action="Update"
                          method="post"
                          enctype="multipart/form-data">

                        <!-- PROFILE IMAGE -->

                        <div class="text-center mb-4">

                            @if (!string.IsNullOrEmpty(Model.ProfileImage))
                            {
                                <img src="~/profiles/@Model.ProfileImage"
                                     class="rounded-circle shadow border border-3 border-warning"
                                     width="150"
                                     height="150"
                                     style="object-fit:cover;" />
                            }
                            else
                            {
                                <img src="https://via.placeholder.com/150"
                                     class="rounded-circle shadow border border-3 border-warning" />
                            }

                        </div>

                        <!-- IMAGE INPUT -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Upload Profile Picture
                            </label>

                            <input type="file"
                                   name="imageFile"
                                   class="form-control form-control-lg" />

                        </div>

                        <div class="row">

                            <!-- FULL NAME -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label fw-semibold">
                                    Full Name
                                </label>

                                <input asp-for="FullName"
                                       class="form-control form-control-lg" />

                            </div>

                            <!-- EMAIL -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label fw-semibold">
                                    Email Address
                                </label>

                                <input asp-for="Email"
                                       class="form-control form-control-lg"
                                       readonly />

                            </div>

                            <!-- PHONE -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label fw-semibold">
                                    Phone Number
                                </label>

                                <input asp-for="PhoneNumber"
                                       class="form-control form-control-lg" />

                            </div>

                            <!-- COUNTRY -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label fw-semibold">
                                    Country
                                </label>

                                <input asp-for="Country"
                                       class="form-control form-control-lg" />

                            </div>

                            <!-- STATE -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label fw-semibold">
                                    State
                                </label>

                                <input asp-for="State"
                                       class="form-control form-control-lg" />

                            </div>

                            <!-- CITY -->

                            <div class="col-md-6 mb-3">

                                <label class="form-label fw-semibold">
                                    City
                                </label>

                                <input asp-for="City"
                                       class="form-control form-control-lg" />

                            </div>

                        </div>

                        <!-- ADDRESS -->

                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Address
                            </label>

                            <textarea asp-for="Address"
                                      class="form-control"
                                      rows="3"></textarea>

                        </div>

                        <!-- BIO -->

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Bio
                            </label>

                            <textarea asp-for="Bio"
                                      class="form-control"
                                      rows="4"></textarea>

                        </div>

                        <!-- BUTTON -->

                        <button type="submit"
                                class="btn btn-dark btn-lg rounded-pill px-5">

                            Save Changes

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}