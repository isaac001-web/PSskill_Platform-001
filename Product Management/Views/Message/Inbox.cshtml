@model IEnumerable<Product_Management.Models.Message>

@using System.Security.Claims

@{
    ViewData["Title"] = "Messages";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var admin = ViewBag.Admin as Product_Management.Models.ApplicationUser;
}

<style>
    .chat-list-wrapper {
        max-width: 680px;
        margin: 0 auto;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .chat-list-header {
        background: #075e54;
        color: #fff;
        padding: 18px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .chat-list-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-bottom: 1px solid #f0f2f5;
        text-decoration: none;
        color: inherit;
        transition: background 0.15s;
        cursor: pointer;
    }

        .chat-list-item:hover {
            background: #f5f6fa;
            color: inherit;
        }

    .chat-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .chat-preview {
        flex: 1;
        min-width: 0;
    }

    .chat-name {
        font-weight: 700;
        font-size: 0.97rem;
        color: #111;
    }

    .chat-last-msg {
        font-size: 0.83rem;
        color: #888;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 320px;
    }

    .chat-time {
        font-size: 0.75rem;
        color: #aaa;
        white-space: nowrap;
    }

    .unread-badge {
        background: #25d366;
        color: #fff;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        font-size: 0.72rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .new-chat-btn {
        position: fixed;
        bottom: 32px;
        right: 32px;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: #25d366;
        color: #fff;
        border: none;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 16px rgba(37,211,102,0.4);
        text-decoration: none;
        transition: background 0.2s;
        z-index: 100;
    }

        .new-chat-btn:hover {
            background: #1ebe5d;
            color: #fff;
        }
</style>

<div class="container py-4">
    <div class="chat-list-wrapper">

        <!-- HEADER -->
        <div class="chat-list-header">
            <div class="fw-bold fs-5">Messages</div>
            <a asp-action="Conversation"
               class="btn btn-sm"
               style="background:#128c7e; color:#fff;
                border-radius:20px; padding:6px 18px;">
                <i class="bi bi-chat-dots-fill me-1"></i>
                Chat with Admin
            </a>
        </div>

        <!-- CHAT LIST -->
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-chat-dots display-1"
                   style="color:#25d366;"></i>
                <h5 class="mt-3 fw-bold">No messages yet</h5>
                <p class="text-muted">
                    Start a conversation with admin support.
                </p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                var isMine = item.SenderId == currentUserId;
                var otherPerson = isMine ? item.Receiver : item.Sender;
                var unread = !item.IsRead && !isMine;

                <a asp-action="Conversation"
                   class="chat-list-item">

                    <img src="~/profiles/@(otherPerson?.ProfileImage ?? "default.png")"
                         class="chat-avatar" />

                    <div class="chat-preview">
                        <div class="d-flex justify-content-between">
                            <span class="chat-name">
                                @(otherPerson?.FullName ?? otherPerson?.Email ?? "Admin")
                            </span>
                            <span class="chat-time">
                                @item.SentAt.ToString("hh:mm tt")
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="chat-last-msg">
                                @if (isMine)
                                {
                                    <span style="color:#aaa;">
                                        <i class="bi bi-check2-all me-1"
                                           style="color:@(item.IsRead ? "#53bdeb" : "#aaa");"></i>
                                    </span>
                                }
                                @item.Content
                            </span>
                            @if (unread)
                            {
                                <span class="unread-badge">1</span>
                            }
                        </div>
                    </div>

                </a>
            }
        }

    </div>
</div>

@section Scripts {
    <script>
        // Auto-refresh every 10 seconds for new messages
        setTimeout(() => location.reload(), 10000);
    </script>
}