
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center"
     style="min-height:70vh;">
    <div class="card border-0 shadow-sm rounded-4 p-4"
         style="width:100%;max-width:440px;">

        <div class="text-center mb-4">
            <div style="width:56px;height:56px;border-radius:50%;
                background:#fef2f2;display:flex;
                align-items:center;justify-content:center;
                margin:0 auto 12px;">
                <i class="bi bi-key"
                   style="font-size:1.6rem;color:#dc2626;"></i>
            </div>
            <h5 class="fw-bold mb-1">Set New Password</h5>
            <p class="text-muted" style="font-size:0.88rem;">
                Choose a strong password for your account.
            </p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-3 py-2 px-3"
                 style="font-size:0.87rem;">
                <i class="bi bi-exclamation-circle me-1"></i>
                @TempData["Error"]
            </div>
        }

        <form method="post"
              asp-action="ResetPassword"
              asp-controller="ForgotPassword">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-semibold"
                       style="font-size:0.88rem;">
                    New Password
                </label>
                <div class="input-group">
                    <span class="input-group-text
                        bg-light border-end-0">
                        <i class="bi bi-lock text-muted"></i>
                    </span>
                    <input type="password"
                           name="newPassword"
                           id="newPassword"
                           required minlength="6"
                           class="form-control border-start-0 ps-0"
                           placeholder="Min. 6 characters" />
                    <button type="button"
                            class="input-group-text bg-light"
                            onclick="togglePass('newPassword',this)">
                        <i class="bi bi-eye text-muted"></i>
                    </button>
                </div>

                <div class="mt-2" id="strengthBar"
                     style="display:none;">
                    <div class="progress"
                         style="height:4px;border-radius:4px;">
                        <div id="strengthFill"
                             class="progress-bar"
                             style="width:0%;transition:width 0.3s;">
                        </div>
                    </div>
                    <small id="strengthLabel"
                           class="text-muted"
                           style="font-size:0.75rem;"></small>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold"
                       style="font-size:0.88rem;">
                    Confirm Password
                </label>
                <div class="input-group">
                    <span class="input-group-text
                        bg-light border-end-0">
                        <i class="bi bi-lock-fill text-muted"></i>
                    </span>
                    <input type="password"
                           name="confirmPassword"
                           id="confirmPassword"
                           required minlength="6"
                           class="form-control border-start-0 ps-0"
                           placeholder="Repeat your password" />
                    <button type="button"
                            class="input-group-text bg-light"
                            onclick="togglePass('confirmPassword',this)">
                        <i class="bi bi-eye text-muted"></i>
                    </button>
                </div>
                <small id="matchMsg"
                       style="font-size:0.78rem;"></small>
            </div>

            <button type="submit"
                    class="btn btn-danger w-100
                rounded-pill fw-semibold py-2">
                <i class="bi bi-check-circle me-1"></i>
                Save New Password
            </button>
        </form>

        <div class="text-center mt-3">
            <a asp-area="Identity"
               asp-page="/Account/Login"
               class="text-muted"
               style="font-size:0.85rem;">
                <i class="bi bi-arrow-left me-1"></i>
                Back to Login
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        function togglePass(id, btn) {
            const input = document.getElementById(id);
            const icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash text-muted';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye text-muted';
            }
        }

        document.getElementById('newPassword')
            .addEventListener('input', function () {
                const val = this.value;
                const bar = document.getElementById('strengthBar');
                const fill = document.getElementById('strengthFill');
                const label = document.getElementById('strengthLabel');

                bar.style.display = val.length ? 'block' : 'none';

                let score = 0;
                if (val.length >= 6) score++;
                if (/[A-Z]/.test(val)) score++;
                if (/[0-9]/.test(val)) score++;
                if (/[^A-Za-z0-9]/.test(val)) score++;

                const levels = [
                    { pct:'25%', cls:'bg-danger',  txt:'Weak'   },
                    { pct:'50%', cls:'bg-warning',  txt:'Fair'   },
                    { pct:'75%', cls:'bg-info',     txt:'Good'   },
                    { pct:'100%',cls:'bg-success',  txt:'Strong' },
                ];

                const lvl = levels[score - 1] || levels[0];
                fill.style.width = lvl.pct;
                fill.className = 'progress-bar ' + lvl.cls;
                label.textContent = lvl.txt;
            });

        document.getElementById('confirmPassword')
            .addEventListener('input', function () {
                const msg = document.getElementById('matchMsg');
                const match = this.value ===
                    document.getElementById('newPassword').value;
                msg.textContent = match
                    ? '✓ Passwords match'
                    : '✗ Passwords do not match';
                msg.style.color = match ? '#16a34a' : '#dc2626';
            });
    </script>
}