@{
    ViewData["Title"] = "Enter Reset Code";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center"
     style="min-height:70vh;">
    <div class="card border-0 shadow-sm rounded-4 p-4 text-center"
         style="width:100%;max-width:440px;">

        <div style="width:56px;height:56px;border-radius:50%;
            background:#fef3c7;display:flex;
            align-items:center;justify-content:center;
            margin:0 auto 16px;">
            <i class="bi bi-envelope-check"
               style="font-size:1.6rem;color:#d97706;"></i>
        </div>

        <h5 class="fw-bold mb-1">Check Your Email</h5>
        <p class="text-muted mb-1" style="font-size:0.88rem;">
            We sent a 6-digit code to
        </p>

        @if (ViewBag.SentTo != null)
        {
            <p class="fw-bold mb-4"
               style="font-size:0.9rem;color:#0f172a;">
                @ViewBag.SentTo
            </p>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-3 py-2 px-3
                text-start mb-3"
                 style="font-size:0.87rem;">
                <i class="bi bi-exclamation-circle me-1"></i>
                @TempData["Error"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success rounded-3 py-2 px-3
                text-start mb-3"
                 style="font-size:0.87rem;">
                <i class="bi bi-check-circle me-1"></i>
                @TempData["Success"]
            </div>
        }

        <form method="post"
              asp-action="VerifyOtp"
              asp-controller="ForgotPassword">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label fw-semibold text-start d-block"
                       style="font-size:0.88rem;">
                    Enter 6-Digit Code
                </label>
                <input type="text"
                       name="otp"
                       id="otpInput"
                       required
                       maxlength="6"
                       inputmode="numeric"
                       class="form-control form-control-lg
                text-center fw-bold rounded-3"
                       placeholder="000000"
                       style="letter-spacing:0.3em;
                font-size:1.5rem;" />
                <small class="text-muted mt-1 d-block"
                       style="font-size:0.78rem;">
                    Code expires in 10 minutes
                </small>
            </div>

            <button type="submit"
                    class="btn btn-primary w-100
                rounded-pill fw-semibold py-2 mb-3">
                <i class="bi bi-check2-circle me-1"></i>
                Verify Code
            </button>
        </form>

        <!-- RESEND -->
        <form method="post"
              asp-action="ResendOtp"
              asp-controller="ForgotPassword">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn btn-link text-muted p-0"
                    style="font-size:0.85rem;">
                Didn't receive it?
                <span class="text-primary fw-semibold">
                    Resend Code
                </span>
            </button>
        </form>

        <div class="mt-3">
            <a asp-controller="ForgotPassword"
               asp-action="Index"
               class="text-muted"
               style="font-size:0.82rem;">
                <i class="bi bi-arrow-left me-1"></i>
                Start Over
            </a>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const otpInput = document.getElementById('otpInput');

        // Numbers only
        otpInput.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '');

            // Auto-submit when 6 digits entered
            if (this.value.length === 6) {
                this.closest('form').submit();
            }
        });

        // Auto-focus on load
        otpInput.focus();
    </script>
}