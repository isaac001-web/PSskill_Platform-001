@model IEnumerable<Product_Management.Models.ApplicationUser>

@{
    ViewData["Title"] = "User Management";
    var userRoles = ViewBag.UserRoles
        as Dictionary<string, IList<string>>
        ?? new Dictionary<string, IList<string>>();
}

<style>
    .user-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f3f4f6;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        padding: 18px 20px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: box-shadow 0.2s;
    }

        .user-card:hover {
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        }

    .user-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid #f59e0b;
    }

    .role-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .role-Admin {
        background: #fee2e2;
        color: #dc2626;
    }

    .role-User {
        background: #dbeafe;
        color: #1d4ed8;
    }
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between
        align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">User Management</h3>
            <p class="text-muted mb-0" style="font-size:0.88rem;">
                @Model.Count() registered users
            </p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- SEARCH -->
    <form method="get" class="mb-4">
        <div class="d-flex gap-2">
            <input type="text" name="search"
                   value="@ViewBag.Search"
                   class="form-control rounded-pill px-4"
                   placeholder="Search by name or email..."
                   style="max-width:380px;" />
            <button type="submit"
                    class="btn btn-dark rounded-pill px-4">
                <i class="bi bi-search me-1"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Users"
                   class="btn btn-outline-secondary rounded-pill px-4">
                    Clear
                </a>
            }
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-people display-1 text-muted"></i>
            <h5 class="mt-3 fw-bold">No users found</h5>
        </div>
    }
    else
    {
        @foreach (var user in Model)
        {
            var roles = userRoles.ContainsKey(user.Id)
                ? userRoles[user.Id]
                : new List<string>();

            <div class="user-card">

                <img src="@(string.IsNullOrEmpty(user.ProfileImage)
                                         ? "/profile/default.png"
                                         : "/profiles/" + user.ProfileImage)"
                     class="user-avatar" />

                <div class="flex-grow-1">
                    <div class="fw-bold" style="font-size:0.95rem;">
                        @(user.FullName ?? "No Name")
                    </div>
                    <div class="text-muted" style="font-size:0.78rem;">
                        @user.Email
                    </div>
                    <div class="mt-1 d-flex gap-1 flex-wrap">
                        @foreach (var role in roles)
                        {
                            <span class="role-badge role-@role">
                                @role
                            </span>
                        }
                        @if (!roles.Any())
                        {
                            <span class="text-muted"
                                  style="font-size:0.72rem;">
                                No role assigned
                            </span>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="UserDetails"
                       asp-route-id="@user.Id"
                       class="btn btn-sm btn-outline-dark
                        rounded-pill px-3">
                        <i class="bi bi-person me-1"></i>
                        View
                    </a>
                    <form asp-action="DeleteUser"
                          method="post"
                          onsubmit="return confirm(
                        'Delete this user permanently?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId"
                               value="@user.Id" />
                        <button type="submit"
                                class="btn btn-sm btn-outline-danger
                            rounded-pill px-3">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </form>
                </div>

            </div>
        }
    }

</div>