@model IEnumerable<Product_Management.Models.Product>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="mb-5">

        <h1 class="fw-bold">
            Admin Dashboard
        </h1>

        <p class="text-muted">
            Store analytics and management.
        </p>

    </div>

