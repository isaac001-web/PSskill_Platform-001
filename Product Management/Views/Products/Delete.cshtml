@model Product_Management.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1 class="text-danger">
    Delete Product
</h1>

<h4>
    Are you sure you want to delete this product?
</h4>

<hr />

<div class="card p-4 shadow">

    <!-- Product Image -->
    <div class="mb-4 text-center">

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="~/images/@Model.ImageUrl"
                 width="200"
                 height="200"
                 style="object-fit:cover;
            border-radius:10px;" />
        }

    </div>

    <dl class="row">

        <dt class="col-sm-3">
            Product Name
        </dt>

        <dd class="col-sm-9">
            @Model.Name
        </dd>

        <dt class="col-sm-3">
            Price
        </dt>

        <dd class="col-sm-9">
            @Model.Price
        </dd>

        <dt class="col-sm-3">
            Quantity
        </dt>

        <dd class="col-sm-9">
            @Model.Quantity
        </dd>

    </dl>

</div>

<br />

<!-- Delete Form -->
<form asp-action="DeleteConfirmed">

    <!-- Hidden Product Id -->
    <input type="hidden"
           asp-for="Id" />

    <!-- Delete Button -->
    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <!-- Cancel Button -->
    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>