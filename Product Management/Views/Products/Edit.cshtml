@model Product_Management.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<h1>Edit Product</h1>

<hr />

<div class="row">

    <div class="col-md-6">

        <form asp-action="Edit"
              enctype="multipart/form-data">

            <!-- Hidden Product Id -->
            <input type="hidden"
                   asp-for="Id" />

            <!-- Hidden Old Image -->
            <input type="hidden"
                   asp-for="ImageUrl" />

            <!-- Validation Errors -->
            <div asp-validation-summary="All"
                 class="text-danger"></div>

            <!-- Product Name -->
            <div class="mb-3">

                <label asp-for="Name"
                       class="form-label"></label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger"></span>

            </div>

            <!-- Product Price -->
            <div class="mb-3">

                <label asp-for="Price"
                       class="form-label"></label>

                <input asp-for="Price"
                       class="form-control" />

                <span asp-validation-for="Price"
                      class="text-danger"></span>

            </div>

            <!-- Product Quantity -->
            <div class="mb-3">

                <label asp-for="Quantity"
                       class="form-label"></label>

                <input asp-for="Quantity"
                       class="form-control" />

                <span asp-validation-for="Quantity"
                      class="text-danger"></span>

            </div>


            <!---added to correct the edit issues---->


            <!-- Category -->
            <div class="mb-3">

                <label asp-for="CategoryId"
                       class="form-label">
                </label>

                <select asp-for="CategoryId"
                        class="form-control"
                        asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                    <option value="">-- Select Category --</option>
                </select>

                <span asp-validation-for="CategoryId"
                      class="text-danger"></span>

            </div>










            <!-- Current Image -->
            <div class="mb-3">

                <label class="form-label">
                    Current Image
                </label>

                <br />

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="~/images/@Model.ImageUrl"
                         width="150"
                         height="150"
                         style="object-fit:cover;
                    border-radius:10px;" />
                }

            </div>

            <!-- Upload New Image -->
            <div class="mb-3">

                <label class="form-label">
                    Change Product Image
                </label>

                <input type="file"
                       name="imageFile"
                       class="form-control" />

            </div>

            <!-- Update Button -->
            <button type="submit"
                    class="btn btn-success">
                Update Product
            </button>

            <!-- Back Button -->
            <a asp-action="Index"
               class="btn btn-secondary">
                Back to List
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}