@model IEnumerable<Product_Management.Models.Order>

@{
    ViewData["Title"] = "My Orders";
}

<style>
    .order-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f3f4f6;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        margin-bottom: 20px;
        overflow: hidden;
        transition: box-shadow 0.2s;
    }

        .order-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,0.10);
        }

    .order-header {
        background: #f9fafb;
        padding: 16px 24px;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
    }

    .order-body {
        padding: 20px 24px;
    }

    /* STATUS BADGE */
    .status-badge {
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.04em;
    }

    .status-Pending {
        background: #fef3c7;
        color: #d97706;
    }

    .status-Processing {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-Shipped {
        background: #ede9fe;
        color: #7c3aed;
    }

    .status-Delivered {
        background: #dcfce7;
        color: #16a34a;
    }

    .status-Cancelled {
        background: #fee2e2;
        color: #dc2626;
    }

    /* TRACKING TIMELINE */
    .timeline {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: 20px 0;
        position: relative;
    }

        .timeline::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 10%;
            right: 10%;
            height: 3px;
            background: #e5e7eb;
            z-index: 0;
        }

    .timeline-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 1;
        flex: 1;
    }

    .timeline-dot {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: #9ca3af;
        margin-bottom: 8px;
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px #e5e7eb;
        transition: all 0.3s;
    }

        .timeline-dot.active {
            background: #111827;
            color: #fff;
            box-shadow: 0 0 0 2px #111827;
        }

        .timeline-dot.done {
            background: #10b981;
            color: #fff;
            box-shadow: 0 0 0 2px #10b981;
        }

        .timeline-dot.cancelled {
            background: #ef4444;
            color: #fff;
            box-shadow: 0 0 0 2px #ef4444;
        }

    .timeline-label {
        font-size: 0.72rem;
        font-weight: 600;
        color: #9ca3af;
        text-align: center;
    }

        .timeline-label.active {
            color: #111827;
        }

        .timeline-label.done {
            color: #10b981;
        }

    /* ORDER ITEMS */
    .order-item-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 10px 0;
        border-bottom: 1px solid #f9fafb;
    }

        .order-item-row:last-child {
            border-bottom: none;
        }

    .order-item-img {
        width: 52px;
        height: 52px;
        border-radius: 10px;
        object-fit: cover;
        background: #f9fafb;
        flex-shrink: 0;
    }

    .cancel-btn {
        background: #fee2e2;
        color: #dc2626;
        border: none;
        border-radius: 10px;
        padding: 8px 18px;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

        .cancel-btn:hover {
            background: #fecaca;
        }
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">My Orders</h3>
            <p class="text-muted mb-0" style="font-size:0.88rem;">
                Track and manage your orders
            </p>
        </div>
        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-dark rounded-pill px-4">
            <i class="bi bi-bag-plus me-2"></i>
            Shop More
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close"
                    data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <h4 class="mt-3 fw-bold">No Orders Yet</h4>
            <p class="text-muted">
                You haven't placed any orders yet.
            </p>
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-dark rounded-pill px-5 mt-2">
                Start Shopping
            </a>
        </div>
    }
    else
    {
        @foreach (var order in Model)
        {
            var steps = new[]
            {
                (OrderStatus.Pending,    "bi-clock",         "Pending"),
                (OrderStatus.Processing, "bi-gear",          "Processing"),
                (OrderStatus.Shipped,    "bi-truck",         "Shipped"),
                (OrderStatus.Delivered,  "bi-check-circle",  "Delivered")
            };

            var isCancelled = order.Status == OrderStatus.Cancelled;
            var currentStep = (int)order.Status;

            <div class="order-card">

                <!-- ORDER HEADER -->
                <div class="order-header">
                    <div>
                        <div class="fw-bold" style="font-size:0.95rem;">
                            Order #@order.Id
                        </div>
                        <div class="text-muted" style="font-size:0.78rem;">
                            Placed on
                            @order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="status-badge
                            status-@order.Status.ToString()">
                            @order.Status.ToString()
                        </span>
                        <div class="fw-bold" style="font-size:1rem;">
                            ₦@order.TotalAmount.ToString("N0")
                        </div>
                    </div>
                </div>

                <!-- ORDER BODY -->
                <div class="order-body">

                    @if (!isCancelled)
                    {
                        <!-- TRACKING TIMELINE -->
                        <div class="timeline">
                            @foreach (var (status, icon, label) in steps)
                            {
                                var stepIndex = (int)status;
                                var dotClass = stepIndex < currentStep
                                    ? "done"
                                    : stepIndex == currentStep
                                        ? "active"
                                        : "";

                                <div class="timeline-step">
                                    <div class="timeline-dot @dotClass">
                                        <i class="bi @icon"></i>
                                    </div>
                                    <div class="timeline-label @dotClass">
                                        @label
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger
                            d-flex align-items-center gap-2
                            rounded-3 py-2 px-3 mb-3"
                             style="font-size:0.85rem;">
                            <i class="bi bi-x-circle-fill"></i>
                            <span>
                                Order cancelled.
                                @if (!string.IsNullOrEmpty(order.CancelReason))
                                {
                                    <strong>Reason:</strong>
                                    @order.CancelReason
                                }
                            </span>
                        </div>
                    }

                    <!-- ORDER ITEMS -->
                    @if (order.OrderItems != null && order.OrderItems.Any())
                    {
                        <div class="mt-3">
                            @foreach (var item in order.OrderItems)
                            {
                                <div class="order-item-row">
                                    @if (item.Product != null &&
                                        !string.IsNullOrEmpty(item.Product.ImageUrl))
                                    {
                                        <img src="~/images/@item.Product.ImageUrl"
                                             class="order-item-img" />
                                    }
                                    else
                                    {
                                        <div class="order-item-img d-flex
                                            align-items-center
                                            justify-content-center
                                            bg-light">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold"
                                             style="font-size:0.9rem;">
                                            @(item.Product?.Name ?? "Product")
                                        </div>
                                        <div class="text-muted"
                                             style="font-size:0.78rem;">
                                            Qty: @item.Quantity ×
                                            ₦@item.Price.ToString("N0")
                                        </div>
                                    </div>
                                    <div class="fw-bold" style="font-size:0.9rem;">
                                        ₦@((item.Price * item.Quantity).ToString("N0"))
                                    </div>
                                </div>
                            }
                        </div>
                    }


                    @* i am trying to acces the product page from this page so as to view the details of the product, how can i do that? *@
                  @*   <div class="card-footer-custom">
                        <a asp-controller="Products"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn-details">
                            Details
                        </a> *@


                    <!-- FOOTER ROW -->
                    <div class="d-flex justify-content-between
                        align-items-center mt-3 pt-3
                        border-top">
                        <a asp-action="OrderDetails"
                           asp-route-id="@order.Id"
                           class="btn btn-sm btn-outline-dark
                            rounded-pill px-3">
                            <i class="bi bi-eye me-1"></i>
                            View Details
                        </a>

                        @if (order.Status == OrderStatus.Pending)
                        {
                            <button class="cancel-btn"
                                    data-bs-toggle="modal"
                                    data-bs-target="#cancelModal"
                                    data-order-id="@order.Id">
                                <i class="bi bi-x-circle me-1"></i>
                                Cancel Order
                            </button>
                        }
                    </div>

                </div>

            </div>
        }
    }

</div>

<!-- CANCEL MODAL -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Cancel Order</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted" style="font-size:0.88rem;">
                    Please provide a reason for cancelling this order.
                </p>
                <form asp-action="CancelOrder"
                      asp-controller="Checkout"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId"
                           id="cancelOrderId" />
                    <div class="mb-3">
                        <textarea name="reason"
                                  class="form-control rounded-3"
                                  rows="3"
                                  placeholder="e.g. Changed my mind..."
                                  required></textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button"
                                class="btn btn-outline-secondary
                            rounded-pill px-4"
                                data-bs-dismiss="modal">
                            Keep Order
                        </button>
                        <button type="submit"
                                class="btn btn-danger rounded-pill px-4">
                            Confirm Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const cancelModal =
                document.getElementById('cancelModal');
            cancelModal.addEventListener('show.bs.modal',
                function (e) {
                    const btn = e.relatedTarget;
                    const orderId =
                        btn.getAttribute('data-order-id');
                    document.getElementById('cancelOrderId')
                        .value = orderId;
                });
        });
    </script>
}