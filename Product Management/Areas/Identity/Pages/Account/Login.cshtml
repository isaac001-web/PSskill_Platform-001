@* 
@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log in</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            * { box-sizing: border-box; margin: 0; padding: 0; }

            body {
                min-height: 100vh;
                background: linear-gradient(135deg, #e8f4fd 0%, #d1e9f6 50%, #bddff0 100%);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', sans-serif;
            }

            .brand {
                text-align: center;
                margin-bottom: 24px;
            }

            .brand span.ps { color: #f5a623; font-size: 1.8rem; font-weight: 700; }
            .brand span.skill { color: #2d6cdf; font-size: 1.8rem; font-weight: 700; }

            .card {
                background: #fff;
                border-radius: 16px;
                box-shadow: 0 8px 32px rgba(45,108,223,0.10);
                padding: 40px 36px 32px;
                width: 100%;
                max-width: 420px;
            }

            .card h2 {
                text-align: center;
                font-size: 1.6rem;
                font-weight: 700;
                color: #1a1a2e;
                margin-bottom: 6px;
            }

            .card .subtitle {
                text-align: center;
                color: #7a8a9a;
                font-size: 0.92rem;
                margin-bottom: 28px;
            }

            .input-group-custom {
                position: relative;
                margin-bottom: 16px;
            }

            .input-group-custom label {
                display: block;
                font-size: 0.88rem;
                font-weight: 600;
                color: #374151;
                margin-bottom: 6px;
            }

            .input-wrapper {
                position: relative;
                display: flex;
                align-items: center;
            }

            .input-wrapper .icon {
                position: absolute;
                left: 14px;
                color: #9ca3af;
                font-size: 1rem;
            }

            .input-wrapper input {
                width: 100%;
                padding: 12px 14px 12px 42px;
                border: 1.5px solid #e5e7eb;
                border-radius: 10px;
                font-size: 0.95rem;
                outline: none;
                transition: border-color 0.2s;
                background: #f9fafb;
            }

            .input-wrapper input:focus {
                border-color: #2d6cdf;
                background: #fff;
            }

            .input-wrapper .toggle-password {
                position: absolute;
                right: 14px;
                cursor: pointer;
                color: #9ca3af;
            }

            .remember-forgot {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 22px;
                font-size: 0.88rem;
            }

            .remember-forgot label { color: #374151; cursor: pointer; }
            .remember-forgot a { color: #2d6cdf; text-decoration: none; }
            .remember-forgot a:hover { text-decoration: underline; }

            .btn-login {
                width: 100%;
                padding: 13px;
                background: #2d6cdf;
                color: #fff;
                border: none;
                border-radius: 10px;
                font-size: 1rem;
                font-weight: 600;
                cursor: pointer;
                transition: background 0.2s;
                margin-bottom: 18px;
            }

            .btn-login:hover { background: #1a56c4; }

            .divider {
                text-align: center;
                color: #9ca3af;
                font-size: 0.85rem;
                margin-bottom: 16px;
                position: relative;
            }

            .divider::before, .divider::after {
                content: '';
                position: absolute;
                top: 50%;
                width: 42%;
                height: 1px;
                background: #e5e7eb;
            }

            .divider::before { left: 0; }
            .divider::after { right: 0; }

            .link-btn {
                display: flex;
                align-items: center;
                justify-content: space-between;
                width: 100%;
                padding: 13px 16px;
                border: 1.5px solid #e5e7eb;
                border-radius: 10px;
                background: #fff;
                color: #374151;
                font-size: 0.93rem;
                text-decoration: none;
                margin-bottom: 10px;
                transition: border-color 0.2s, background 0.2s;
            }

            .link-btn:hover { border-color: #2d6cdf; background: #f0f6ff; color: #2d6cdf; }

            .link-btn .link-icon { color: #2d6cdf; font-size: 1.1rem; }
            .link-btn .arrow { color: #9ca3af; }

            .footer-text {
                text-align: center;
                margin-top: 18px;
                font-size: 0.82rem;
                color: #9ca3af;
            }

            .text-danger { font-size: 0.82rem; color: #e53e3e; margin-top: 4px; display: block; }
    </style>
</head>
<body>

    <div class="brand">
        <span class="ps">PS</span> <span class="skill">skill</span>
    </div>

    <div class="card">
        <h2>Log in</h2>
        <p class="subtitle">Use a local account to log in.</p>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

        <form id="account" method="post">
            <div class="input-group-custom">
                <label asp-for="Input.Email">Email</label>
                <div class="input-wrapper">
                    <span class="icon">✉</span>
                    <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="input-group-custom">
                <label asp-for="Input.Password">Password</label>
                <div class="input-wrapper">
                    <span class="icon"></span>
                    <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="Password" id="passwordInput" />
                    <span class="toggle-password" onclick="togglePassword()">👁</span>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="remember-forgot">
                <label>
                    <input class="form-check-input me-1" asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
                <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
            </div>

            <button id="login-submit" type="submit" class="btn-login">Log in</button>
        </form>

        <div class="divider">OR</div>

        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link-btn">
            <span>
                <span class="link-icon me-2"></span> Register as a new user
            </span>
            <span class="arrow">›</span>
        </a>

        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="link-btn">
            <span>
                <span class="link-icon me-2">✉</span> Resend email confirmation
            </span>
            <span class="arrow">›</span>
        </a>
    </div>

    <div class="footer-text">© 2026 PS skill. All rights reserved.</div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePassword() {
        const input = document.getElementById('passwordInput');
        input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
</body>
</html>

