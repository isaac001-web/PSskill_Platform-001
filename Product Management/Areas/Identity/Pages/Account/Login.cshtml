<body>

    <div class="brand">
        <span class="ps">PS</span> <span class="skill">skill</span>
    </div>

    <div class="card">
        <h2>Log in</h2>
        <p class="subtitle">Use a local account to log in.</p>

        @* SHOW NOTICE IF REDIRECTED FROM CART *@
        @if (!string.IsNullOrEmpty(Model.ReturnUrl) &&
             Model.ReturnUrl.Contains("Cart"))
        {
            <div class="cart-notice">
                <span style="font-size:1.1rem;">🛒</span>
                <span>
                    Please log in to add items to your cart.
                    You'll be redirected back automatically.
                </span>
            </div>
        }

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3" role="alert"></div>

        <form id="account" method="post">

            @* PRESERVE RETURN URL *@
            <input type="hidden"
                   name="ReturnUrl"
                   value="@Model.ReturnUrl" />

            <div class="input-group-custom">
                <label asp-for="Input.Email">Email</label>
                <div class="input-wrapper">
                    <span class="icon">✉</span>
                    <input asp-for="Input.Email"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="name@example.com" />
                </div>
                <span asp-validation-for="Input.Email"
                      class="text-danger"></span>
            </div>

            <div class="input-group-custom">
                <label asp-for="Input.Password">Password</label>
                <div class="input-wrapper">
                    <span class="icon">🔒</span>
                    <input asp-for="Input.Password"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="Password"
                           id="passwordInput" />
                    <span class="toggle-password"
                          onclick="togglePassword()">👁</span>
                </div>
                <span asp-validation-for="Input.Password"
                      class="text-danger"></span>
            </div>

            <div class="remember-forgot">
                <label>
                    <input class="form-check-input me-1"
                           asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
               @*  <a id="forgot-password"
                   asp-page="./ForgotPassword">
                    Forgot your password?
                </a> *@


                <a asp-controller="ForgotPassword" asp-action="Index" class="text-decoration-none">
                    Forgot your password?
                </a>
            </div>

            <button id="login-submit"
                    type="submit"
                    class="btn-login">
                Log in
            </button>

        </form>

        <div class="divider">OR</div>

        <a asp-page="./Register"
           asp-route-returnUrl="@Model.ReturnUrl"
           class="link-btn">
            <span>
                <span class="link-icon me-2">👤</span>
                Register as a new user
            </span>
            <span class="arrow">›</span>
        </a>

        <a id="resend-confirmation"
           asp-page="./ResendEmailConfirmation"
           class="link-btn">
            <span>
                <span class="link-icon me-2">✉</span>
                Resend email confirmation
            </span>
            <span class="arrow">›</span>
        </a>

    </div>

    <div class="footer-text">
        © 2026 PS skill. All rights reserved.
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePassword() {
        const input = document.getElementById('passwordInput');
        input.type = input.type === 'password'
        ? 'text' : 'password';
        }
    </script>

</body>
</html>